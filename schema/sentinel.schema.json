{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/coffeebot-agent/openclaw-sentinel/main/schema/sentinel.schema.json",
  "title": "OpenClaw Sentinel Watcher Config",
  "description": "Declarative watcher schema for @coffeexdev/openclaw-sentinel",
  "type": "object",
  "additionalProperties": false,
  "required": ["watchers"],
  "properties": {
    "watchers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/watcher" }
    }
  },
  "$defs": {
    "operator": {
      "type": "string",
      "enum": [
        "eq",
        "neq",
        "gt",
        "gte",
        "lt",
        "lte",
        "exists",
        "absent",
        "contains",
        "matches",
        "changed"
      ]
    },
    "templateValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/templateValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/templateValue" }
        }
      ]
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "op"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "op": { "$ref": "#/$defs/operator" },
        "value": {}
      }
    },
    "fire": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventName", "payloadTemplate"],
      "properties": {
        "webhookPath": {
          "type": "string",
          "pattern": "^/",
          "default": "/hooks/sentinel"
        },
        "eventName": { "type": "string", "minLength": 1 },
        "payloadTemplate": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/templateValue" }
        },
        "intent": { "type": "string", "minLength": 1 },
        "contextTemplate": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/templateValue" }
        },
        "priority": {
          "type": "string",
          "enum": ["low", "normal", "high", "critical"]
        },
        "deadlineTemplate": { "type": "string", "minLength": 1 },
        "dedupeKeyTemplate": { "type": "string", "minLength": 1 },
        "notificationPayloadMode": {
          "type": "string",
          "enum": ["inherit", "none", "concise", "debug"],
          "description": "Per-watcher notification payload mode override for deliveryTargets"
        },
        "sessionGroup": { "type": "string", "minLength": 1 },
        "operatorGoal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 20000,
          "description": "Watcher callback success criteria text. Runtime default limit is 12000 chars unless maxOperatorGoalChars override is set."
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRetries", "baseMs", "maxMs"],
      "properties": {
        "maxRetries": { "type": "integer", "minimum": 0, "maximum": 20 },
        "baseMs": { "type": "integer", "minimum": 50, "maximum": 60000 },
        "maxMs": { "type": "integer", "minimum": 100, "maximum": 300000 }
      }
    },
    "evmCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["to", "signature"],
      "properties": {
        "to": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$",
          "description": "Contract address (0x-prefixed, 20-byte hex)"
        },
        "signature": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable ABI signature, e.g. \"function balanceOf(address) view returns (uint256)\""
        },
        "args": {
          "type": "array",
          "items": {},
          "description": "Call arguments matching the ABI signature parameters"
        },
        "blockTag": {
          "type": "string",
          "minLength": 1,
          "description": "Block tag for eth_call (default \"latest\")"
        }
      }
    },
    "deliveryTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["channel", "to"],
      "properties": {
        "channel": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "accountId": { "type": "string", "minLength": 1 }
      }
    },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "skillId",
        "enabled",
        "strategy",
        "endpoint",
        "match",
        "conditions",
        "fire",
        "retry"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{1,128}$",
          "maxLength": 128
        },
        "skillId": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "strategy": {
          "type": "string",
          "enum": ["http-poll", "websocket", "sse", "http-long-poll", "evm-call"]
        },
        "endpoint": { "type": "string", "format": "uri" },
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": { "type": "string" },
        "intervalMs": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "match": { "type": "string", "enum": ["all", "any"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/condition" }
        },
        "fire": { "$ref": "#/$defs/fire" },
        "retry": { "$ref": "#/$defs/retry" },
        "fireOnce": { "type": "boolean" },
        "deliveryTargets": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/deliveryTarget" }
        },
        "evmCall": { "$ref": "#/$defs/evmCall" },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
