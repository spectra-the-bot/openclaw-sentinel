{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/coffeebot-agent/openclaw-sentinel/main/schema/sentinel.schema.json",
  "title": "OpenClaw Sentinel Watcher Config",
  "description": "Declarative watcher schema for @coffeexdev/openclaw-sentinel",
  "type": "object",
  "additionalProperties": false,
  "required": ["watchers"],
  "properties": {
    "watchers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/watcher" }
    }
  },
  "$defs": {
    "operator": {
      "type": "string",
      "enum": [
        "eq",
        "neq",
        "gt",
        "gte",
        "lt",
        "lte",
        "exists",
        "absent",
        "contains",
        "matches",
        "changed"
      ]
    },
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "op"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "op": { "$ref": "#/$defs/operator" },
        "value": {}
      }
    },
    "fire": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventName", "payloadTemplate"],
      "properties": {
        "webhookPath": {
          "type": "string",
          "pattern": "^/",
          "default": "/hooks/sentinel"
        },
        "eventName": { "type": "string", "minLength": 1 },
        "payloadTemplate": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" },
              { "type": "null" }
            ]
          }
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxRetries", "baseMs", "maxMs"],
      "properties": {
        "maxRetries": { "type": "integer", "minimum": 0, "maximum": 20 },
        "baseMs": { "type": "integer", "minimum": 50, "maximum": 60000 },
        "maxMs": { "type": "integer", "minimum": 100, "maximum": 300000 }
      }
    },
    "watcher": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "skillId",
        "enabled",
        "strategy",
        "endpoint",
        "match",
        "conditions",
        "fire",
        "retry"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "skillId": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "strategy": {
          "type": "string",
          "enum": ["http-poll", "websocket", "sse", "http-long-poll"]
        },
        "endpoint": { "type": "string", "format": "uri" },
        "method": { "type": "string", "enum": ["GET", "POST"] },
        "headers": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "body": { "type": "string" },
        "intervalMs": { "type": "integer", "minimum": 1 },
        "timeoutMs": { "type": "integer", "minimum": 1 },
        "match": { "type": "string", "enum": ["all", "any"] },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/condition" }
        },
        "fire": { "$ref": "#/$defs/fire" },
        "retry": { "$ref": "#/$defs/retry" },
        "fireOnce": { "type": "boolean" },
        "metadata": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    }
  }
}
